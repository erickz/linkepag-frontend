# Variáveis de Ambiente - Frontend

# ============================================
# CONFIGURAÇÕES OBRIGATÓRIAS
# ============================================

# URL da API do backend (obrigatório)
# Desenvolvimento local: http://localhost:3001
# Produção: https://api.linkepag.com.br
NEXT_PUBLIC_API_URL=http://localhost:3001

# URL pública da aplicação (usada em metadata/links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Porta da aplicação (usada em Docker)
NEXT_PUBLIC_APP_PORT=3000

# Chave pública do MercadoPago (obrigatório para pagamentos)
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-f44e5241-2552-4c54-b72c-8fd1a9f7c1e2

# ============================================
# CONFIGURAÇÕES DO PIX DA LINKEPAG (Planos)
# ============================================

NEXT_PUBLIC_LINKEPAG_PIX_KEY=pix@linkepag.com
NEXT_PUBLIC_LINKEPAG_PIX_KEY_TYPE=EMAIL
NEXT_PUBLIC_LINKEPAG_PIX_NAME=LinkePag Tecnologia
NEXT_PUBLIC_LINKEPAG_PIX_CITY=Sao Paulo
# NEXT_PUBLIC_LINKEPAG_PIX_QR_CODE_URL=  # Opcional: URL da imagem QR Code

# ============================================
# CONFIGURAÇÕES DE DESENVOLVIMENTO
# ============================================

# Ambiente
NODE_ENV=development

# Desabilitar telemetria do Next.js (mensagens no console)
NEXT_TELEMETRY_DISABLED=1

# Configuração HMR WebSocket (evita warnings do Turbopack)
# NEXT_PUBLIC_HMR_WEBSOCKET_PORT=0  # Desabilita WebSocket HMR

# ============================================
# NOTAS IMPORTANTES
# ============================================
# - Variáveis com prefixo NEXT_PUBLIC_ são expostas no frontend
# - NUNCA coloque secrets aqui (use apenas no backend)
# - Em produção, configure no Vercel Dashboard
# - O componente ErrorSuppressor já suprime warnings de HMR automaticamente